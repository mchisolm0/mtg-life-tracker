{
  "name": "mtg-life-tracker",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "convex": "^1.41.0",
    "expo": "~56.0.12",
    "expo-dev-client": "~56.0.20",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@react-native-community/cli": "20.1.3",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:clean": "expo prebuild --clean",
    "typecheck": "tsc --noEmit",
    "doctor": "bunx expo-doctor@latest",
    "export:web": "expo export --platform web",
    "build:ios:sim": "NODE_ENV=development bunx eas-cli build --profile development --platform ios --local",
    "build:ios:dev": "NODE_ENV=development bunx eas-cli build --profile development:device --platform ios --local",
    "build:android:dev": "NODE_ENV=development bunx eas-cli build --profile development --platform android --local",
    "convex:codegen": "convex codegen --typecheck try",
    "test": "bun test tests",
    "test:contract": "bun test tests/matchEventContract.test.js",
    "test:convex-sync": "bun test tests/convexMatchApi.test.js tests/matchSyncCoordinator.test.js",
    "test:remote-link": "bun test tests/remoteMatchLink.test.js",
    "test:storage": "bun test tests/localMatchStoreCore.test.js",
    "test:sync": "bun test tests/matchOutboxSync.test.js",
    "test:sync-runtime": "bun test tests/matchSyncRuntimeCore.test.js"
  },
  "private": true
}
